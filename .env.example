# ==============================
# Pixel Movies — Environment Variables
# ==============================
# Copy this file to .env and fill in the values

# TMDB API Key (get yours at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# JWT Secret (use a long, random string)
JWT_SECRET=your-jwt-secret-change-me-to-a-random-string

# Flask Secret Key
SECRET_KEY=your-flask-secret-change-me-to-a-random-string

# Database Password
DB_PASSWORD=pixelmovies123

# Domain (leave empty for local-only development)
DOMAIN=

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=5000
DB_PORT=5432
REDIS_PORT=6379
